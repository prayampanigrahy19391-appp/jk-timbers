generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// -----------------------------------------------------------------------------
// ENUMS
// -----------------------------------------------------------------------------

enum Role {
  USER
  CUSTOMER
  CONTRACTOR
  STAFF
  ADMIN
  SUPER_ADMIN
}

enum OrderStatus {
  PENDING
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}

enum PaymentStatus {
  UNPAID
  PENDING
  PAID
  REFUNDED
}

enum PaymentMethod {
  COD
  BANK
}

enum ApplicationStatus {
  PENDING
  APPROVED
  REJECTED
}

// -----------------------------------------------------------------------------
// USER & AUTHENTICATION
// -----------------------------------------------------------------------------

model User {
  id                    String                  @id @default(cuid())
  name                  String?
  email                 String?                 @unique
  emailVerified         DateTime?               @map("email_verified")
  image                 String?
  password              String?                 // Nullable for OAuth
  phone                 String?
  role                  Role                    @default(USER)
  createdAt             DateTime                @default(now()) @map("created_at")
  updatedAt             DateTime                @updatedAt @map("updated_at")

  orders                Order[]
  addresses             Address[]
  contactSubmissions    ContactSubmission[]
  contractorApplication ContractorApplication?
  accounts              Account[]
  sessions              Session[]

  @@map("users")
}

model Address {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  street    String
  city      String
  zipCode   String
  isDefault Boolean  @default(false) @map("is_default")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("addresses")
}

model Account {
  id                 String  @id @default(cuid())
  userId             String  @map("user_id")
  type               String
  provider           String
  providerAccountId  String  @map("provider_account_id")
  refresh_token      String? @db.Text
  access_token       String? @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String? @db.Text
  session_state      String?
 
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
 
  @@unique([provider, providerAccountId])
  @@map("accounts")
}
 
model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
 
  @@map("sessions")
}

// -----------------------------------------------------------------------------
// PRODUCT SYSTEM
// -----------------------------------------------------------------------------

model Category {
  id          String    @id @default(cuid())
  name        String    @unique
  slug        String    @unique
  description String?
  image       String?
  sortOrder   Int       @default(0) @map("sort_order")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  products    Product[]

  @@map("categories")
}

model Product {
  id               String   @id @default(cuid())
  name             String
  slug             String   @unique
  description      String
  price            Decimal  @db.Decimal(10, 2)
  unit             String   @default("sq.ft") // sq.ft, cubic feet, piece
  stock            Int      @default(0)
  isActive         Boolean  @default(true) @map("is_active")
  
  categoryId       String   @map("category_id")
  category         Category @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  
  // Product Details (Flat for performance, can be normalized later if needed)
  badge            String?
  features         String[] // PostgreSQL string array
  origin           String?
  
  thickness        String?
  density          String?
  durabilityScore  Int?     @map("durability_score")
  waterResistant   Boolean  @default(false) @map("water_resistant")
  fireResistant    Boolean  @default(false) @map("fire_resistant")
  termiteResistant Boolean  @default(false) @map("termite_resistant")
  weight           String?
  dimensions       String?
  grade            String?
  warranty         String?
  deliveryTimeline String?  @map("delivery_timeline")
  
  // Media
  images           Json     // Replaced String with Json for PG
  model3D          String?  @map("model_3d")
  
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  orderItems       OrderItem[]

  @@index([categoryId])
  @@index([isActive])
  @@map("products")
}

// -----------------------------------------------------------------------------
// ORDERS & CHECKOUT
// -----------------------------------------------------------------------------

model Order {
  id              String        @id @default(cuid())
  
  // Optional link to registered user
  userId          String?       @map("user_id")
  user            User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  
  // Snapshot of customer details at time of order (immutable)
  customerName    String        @map("customer_name")
  email           String
  phone           String
  deliveryAddress String        @map("delivery_address")
  city            String
  zipCode         String        @map("zip_code")
  
  status          OrderStatus   @default(PENDING)
  paymentStatus   PaymentStatus @default(UNPAID) @map("payment_status")
  paymentMethod   PaymentMethod @default(COD) @map("payment_method")
  
  total           Decimal       @db.Decimal(12, 2)
  
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  orderItems      OrderItem[]
  statusHistory   OrderStatusHistory[]

  @@index([userId])
  @@index([status])
  @@index([email])
  @@map("orders")
}

model OrderItem {
  id        String   @id @default(cuid())
  
  orderId   String   @map("order_id")
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  
  productId String   @map("product_id")
  product   Product  @relation(fields: [productId], references: [id], onDelete: Restrict)
  
  quantity  Int
  price     Decimal  @db.Decimal(10, 2) // Snapshot of price at time of order

  @@index([orderId])
  @@index([productId])
  @@map("order_items")
}

model OrderStatusHistory {
  id        String      @id @default(cuid())
  orderId   String      @map("order_id")
  order     Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  status    OrderStatus
  notes     String?
  createdAt DateTime    @default(now()) @map("created_at")

  @@index([orderId])
  @@map("order_status_history")
}

// -----------------------------------------------------------------------------
// FORMS & LEADS
// -----------------------------------------------------------------------------

model ContactSubmission {
  id        String   @id @default(cuid())
  userId    String?  @map("user_id")
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  
  firstName String   @map("first_name")
  lastName  String?  @map("last_name")
  phone     String
  message   String?
  
  createdAt DateTime @default(now()) @map("created_at")

  @@map("contact_submissions")
}

model ContractorApplication {
  id          String            @id @default(cuid())
  userId      String?           @unique @map("user_id")
  user        User?             @relation(fields: [userId], references: [id], onDelete: SetNull)
  
  firstName   String            @map("first_name")
  lastName    String?           @map("last_name")
  company     String?
  gstNumber   String?           @map("gst_number")
  email       String
  
  status      ApplicationStatus @default(PENDING)
  
  createdAt   DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime          @updatedAt @map("updated_at")

  @@map("contractor_applications")
}
