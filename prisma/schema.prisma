generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// -----------------------------------------------------------------------------
// ENUMS
// -----------------------------------------------------------------------------

enum Role {
  USER
  CUSTOMER
  CONTRACTOR
  STAFF
  ADMIN
  SUPER_ADMIN
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  PACKED
  SHIPPED
  DELIVERED
  COMPLETED
  CANCELLED
  REFUNDED
}

enum PaymentStatus {
  UNPAID
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum PaymentProvider {
  RAZORPAY
  STRIPE
  PAYPAL
  UPI
  PHONEPE
  GOOGLE_PAY
  PAYTM
  BHIM
  COD
}

enum PaymentMethod {
  COD
  BANK
  UPI
}

enum PaymentTransactionType {
  CHARGE
  REFUND
}

enum ProductStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum MediaType {
  IMAGE
  THUMBNAIL
  VIDEO
}

enum InventoryTransactionSource {
  ORDER_CREATION
  ORDER_CANCELLATION
  RESTOCK
  MANUAL_ADJUSTMENT
  RETURN
}

enum CartStatus {
  ACTIVE
  CHECKED_OUT
  ABANDONED
}

enum ApplicationStatus {
  PENDING
  APPROVED
  REJECTED
}

// -----------------------------------------------------------------------------
// USER & AUTHENTICATION
// -----------------------------------------------------------------------------

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime? @map("email_verified")
  image         String?
  password      String? // Nullable for OAuth
  phone         String?   @unique
  role          Role      @default(USER)
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  orders                Order[]
  addresses             Address[]
  contactSubmissions    ContactSubmission[]
  contractorApplication ContractorApplication?
  accounts              Account[]
  sessions              Session[]
  carts                 Cart[]

  @@map("users")
}

model Address {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  street    String
  city      String
  zipCode   String
  isDefault Boolean  @default(false) @map("is_default")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("addresses")
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

// -----------------------------------------------------------------------------
// PRODUCT SYSTEM
// -----------------------------------------------------------------------------

model Category {
  id             String     @id @default(cuid())
  name           String     @unique
  slug           String     @unique
  description    String?
  image          String?
  isActive       Boolean    @default(true) @map("is_active")
  sortOrder      Int        @default(0) @map("sort_order")
  parentId       String?    @map("parent_id")
  parentCategory Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  subcategories  Category[] @relation("CategoryHierarchy")
  createdAt      DateTime   @default(now()) @map("created_at")
  updatedAt      DateTime   @updatedAt @map("updated_at")

  products Product[]

  @@index([parentId])
  @@index([isActive])
  @@map("categories")
}

model Tag {
  id        String       @id @default(cuid())
  name      String       @unique
  slug      String       @unique
  products  ProductTag[]
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")

  @@map("tags")
}

model ProductTag {
  productId String  @map("product_id")
  tagId     String  @map("tag_id")
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  tag       Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([productId, tagId])
  @@map("product_tags")
}

model ProductMedia {
  id        String    @id @default(cuid())
  productId String    @map("product_id")
  product   Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  type      MediaType @default(IMAGE)
  url       String
  storageKey String?   @map("storage_key")
  altText   String?
  mimeType  String?   @map("mime_type")
  size      Int?
  width     Int?
  height    Int?
  isPrimary Boolean   @default(false) @map("is_primary")
  sortOrder Int       @default(0) @map("sort_order")
  createdAt DateTime  @default(now()) @map("created_at")

  @@index([productId, sortOrder])
  @@index([isPrimary])
  @@map("product_media")
}

model ProductVariant {
  id        String   @id @default(cuid())
  productId String   @map("product_id")
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  sku       String   @unique
  name      String
  price     Decimal  @db.Decimal(10, 2)
  unit      String?
  image     String?
  attributes Json?
  dimensions Json?
  stock     Int      @default(0)
  lowStockThreshold Int @default(10) @map("low_stock_threshold")
  sortOrder Int      @default(0) @map("sort_order")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  orderItems            OrderItem[]
  inventoryTransactions InventoryTransaction[]
  cartItems             CartItem[]

  @@index([productId])
  @@index([isActive])
  @@map("product_variants")
}

model InventoryTransaction {
  id             String                     @id @default(cuid())
  productId      String?                    @map("product_id")
  variantId      String?                    @map("variant_id")
  warehouseId    String?                    @map("warehouse_id")
  orderId        String?                    @map("order_id")
  quantityChange Int
  stockBefore    Int?                       @map("stock_before")
  stockAfter     Int?                       @map("stock_after")
  source         InventoryTransactionSource @default(MANUAL_ADJUSTMENT)
  reason         String
  metadata       Json?
  actorId        String?                    @map("actor_id")
  createdAt      DateTime                   @default(now()) @map("created_at")

  product Product?        @relation(fields: [productId], references: [id], onDelete: SetNull)
  variant ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)
  warehouse Warehouse?    @relation(fields: [warehouseId], references: [id], onDelete: SetNull)
  order   Order?          @relation(fields: [orderId], references: [id], onDelete: SetNull)

  @@index([productId])
  @@index([variantId])
  @@index([warehouseId])
  @@index([orderId])
  @@index([createdAt])
  @@map("inventory_transactions")
}

model Warehouse {
  id        String   @id @default(cuid())
  name      String
  code      String   @unique
  address   String?
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  inventoryTransactions InventoryTransaction[]

  @@index([isActive])
  @@map("warehouses")
}

model Cart {
  id        String     @id @default(cuid())
  userId    String?    @map("user_id")
  token     String     @unique
  status    CartStatus @default(ACTIVE)
  total     Decimal    @default(0) @db.Decimal(12, 2)
  expiresAt DateTime?  @map("expires_at")
  checkedOutAt DateTime? @map("checked_out_at")
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")

  user  User?      @relation(fields: [userId], references: [id], onDelete: Cascade)
  items CartItem[]
  order Order?

  @@index([userId, status])
  @@index([status])
  @@map("carts")
}

model CartItem {
  id           String   @id @default(cuid())
  cartId       String   @map("cart_id")
  productId    String?  @map("product_id")
  variantId    String?  @map("variant_id")
  sku          String
  name         String
  unit         String
  image        String
  quantity     Int
  price        Decimal  @db.Decimal(10, 2)
  itemSnapshot Json?
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  cart    Cart            @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product Product?        @relation(fields: [productId], references: [id], onDelete: SetNull)
  variant ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)

  @@unique([cartId, sku])
  @@index([cartId])
  @@index([productId])
  @@index([variantId])
  @@map("cart_items")
}

model Product {
  id               String        @id @default(cuid())
  name             String
  slug             String        @unique
  sku              String        @unique
  categoryId       String        @map("category_id")
  category         Category      @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  status           ProductStatus @default(PUBLISHED)
  description      String
  basePrice        Decimal       @map("price") @db.Decimal(10, 2)
  unit             String        @default("sq.ft")
  stock            Int           @default(0)
  lowStockThreshold Int          @default(10) @map("low_stock_threshold")
  isActive         Boolean       @default(true) @map("is_active")
  badge            String?
  features         String[]
  specifications   Json?
  searchKeywords   String[]      @default([]) @map("search_keywords")
  origin           String?
  thumbnail        String?
  images           Json
  model3D          String?       @map("model_3d")
  thickness        String?
  density          String?
  durabilityScore  Int?          @map("durability_score")
  waterResistant   Boolean       @default(false) @map("water_resistant")
  fireResistant    Boolean       @default(false) @map("fire_resistant")
  termiteResistant Boolean       @default(false) @map("termite_resistant")
  weight           String?
  dimensions       String?
  grade            String?
  warranty         String?
  deliveryTimeline String?       @map("delivery_timeline")
  publishedAt      DateTime?     @map("published_at")
  createdAt        DateTime      @default(now()) @map("created_at")
  updatedAt        DateTime      @updatedAt @map("updated_at")

  variants             ProductVariant[]
  media                ProductMedia[]
  productTags          ProductTag[]
  orderItems           OrderItem[]
  inventoryTransactions InventoryTransaction[]
  cartItems            CartItem[]

  @@index([categoryId])
  @@index([status])
  @@index([isActive])
  @@index([basePrice])
  @@index([createdAt])
  @@map("products")
}

// -----------------------------------------------------------------------------
// ORDERS & CHECKOUT
// -----------------------------------------------------------------------------

model Order {
  id String @id @default(cuid())
  orderNumber String @unique @map("order_number")

  // Optional link to registered user
  userId String? @map("user_id")
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  // Optional source cart. Unique to make checkout conversion idempotent.
  cartId String? @unique @map("cart_id")
  cart   Cart?   @relation(fields: [cartId], references: [id], onDelete: SetNull)

  // Snapshot of customer details at time of order (immutable)
  customerName    String @map("customer_name")
  email           String
  phone           String
  deliveryAddress String @map("delivery_address")
  city            String
  zipCode         String @map("zip_code")

  status        OrderStatus   @default(PENDING)
  paymentStatus PaymentStatus @default(UNPAID) @map("payment_status")
  paymentMethod PaymentMethod @default(COD) @map("payment_method")

  subtotal      Decimal @default(0) @db.Decimal(12, 2)
  taxTotal      Decimal @default(0) @map("tax_total") @db.Decimal(12, 2)
  deliveryFee   Decimal @default(0) @map("delivery_fee") @db.Decimal(12, 2)
  discountTotal Decimal @default(0) @map("discount_total") @db.Decimal(12, 2)
  total         Decimal @db.Decimal(12, 2)
  currency      String  @default("INR")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  orderItems           OrderItem[]
  statusHistory        OrderStatusHistory[]
  inventoryTransactions InventoryTransaction[]
  paymentAttempts      PaymentAttempt[]
  paymentTransactions  PaymentTransaction[]
  refunds              Refund[]
  invoice              Invoice?
  paymentAuditLogs     PaymentAuditLog[]

  @@index([userId])
  @@index([cartId])
  @@index([orderNumber])
  @@index([status])
  @@index([email])
  @@index([createdAt])
  @@map("orders")
}

model OrderItem {
  id String @id @default(cuid())

  orderId String @map("order_id")
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  productId String?  @map("product_id")
  product   Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  variantId String?         @map("variant_id")
  variant   ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)

  sku      String
  name     String
  quantity Int
  price    Decimal @db.Decimal(10, 2)
  unit     String
  lineTotal Decimal @default(0) @map("line_total") @db.Decimal(12, 2)
  itemSnapshot Json? @map("item_snapshot")

  @@index([orderId])
  @@index([productId])
  @@index([variantId])
  @@map("order_items")
}

model OrderStatusHistory {
  id        String      @id @default(cuid())
  orderId   String      @map("order_id")
  order     Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  status    OrderStatus
  notes     String?
  actorId   String?     @map("actor_id")
  createdAt DateTime    @default(now()) @map("created_at")

  @@index([orderId])
  @@map("order_status_history")
}

// -----------------------------------------------------------------------------
// FORMS & LEADS
// -----------------------------------------------------------------------------

model ContactSubmission {
  id     String  @id @default(cuid())
  userId String? @map("user_id")
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  firstName String  @map("first_name")
  lastName  String? @map("last_name")
  phone     String
  message   String?

  createdAt DateTime @default(now()) @map("created_at")

  @@map("contact_submissions")
}

model ContractorApplication {
  id           String            @id @default(cuid())
  userId       String?           @unique @map("user_id")
  user         User?             @relation(fields: [userId], references: [id], onDelete: SetNull)
  firstName    String            @map("first_name")
  lastName     String?           @map("last_name")
  company      String?
  gstNumber    String?           @map("gst_number")
  email        String            @unique
  phone        String?
  city         String?
  businessType String?           @map("business_type")
  status       ApplicationStatus @default(PENDING)
  adminNotes   String?           @map("admin_notes")
  discountRate Decimal?          @map("discount_rate") @db.Decimal(5, 2)
  approvedAt   DateTime?         @map("approved_at")
  reviewedAt   DateTime?         @map("reviewed_at")
  reviewedById String?           @map("reviewed_by_id")
  createdAt    DateTime          @default(now()) @map("created_at")
  updatedAt    DateTime          @updatedAt @map("updated_at")

  @@index([email])
  @@index([status])
  @@map("contractor_applications")
}

// -----------------------------------------------------------------------------
// PAYMENT ATTEMPTS & EVENTS
// -----------------------------------------------------------------------------

model PaymentAttempt {
  id               String   @id @default(cuid())
  orderId          String?  @map("order_id")
  order            Order?   @relation(fields: [orderId], references: [id], onDelete: SetNull)
  provider         PaymentProvider
  providerRef      String?  @map("provider_ref")
  status           PaymentStatus @default(PENDING)
  amount           Decimal  @db.Decimal(12, 2)
  currency         String   @default("INR")
  idempotencyKey   String?  @map("idempotency_key")
  providerSessionId String? @map("provider_session_id")
  expiresAt        DateTime? @map("expires_at")
  metadata         Json?
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  events      PaymentEvent[]
  transactions PaymentTransaction[]
  refunds     Refund[]
  auditLogs   PaymentAuditLog[]

  @@index([orderId])
  @@unique([idempotencyKey])
  @@map("payment_attempts")
}

model PaymentTransaction {
  id                   String                 @id @default(cuid())
  attemptId            String?                @map("attempt_id")
  attempt              PaymentAttempt?        @relation(fields: [attemptId], references: [id], onDelete: SetNull)
  orderId              String?                @map("order_id")
  order                Order?                 @relation(fields: [orderId], references: [id], onDelete: SetNull)
  provider             PaymentProvider
  providerTransactionId String?               @map("provider_transaction_id")
  type                 PaymentTransactionType
  amount               Decimal                @db.Decimal(12, 2)
  currency             String                 @default("INR")
  status               String
  metadata             Json?
  createdAt            DateTime               @default(now()) @map("created_at")
  updatedAt            DateTime               @updatedAt @map("updated_at")

  @@index([orderId])
  @@index([attemptId])
  @@map("payment_transactions")
}

model Refund {
  id               String   @id @default(cuid())
  orderId          String?  @map("order_id")
  order            Order?   @relation(fields: [orderId], references: [id], onDelete: SetNull)
  attemptId        String?  @map("attempt_id")
  attempt          PaymentAttempt? @relation(fields: [attemptId], references: [id], onDelete: SetNull)
  auditLogs        PaymentAuditLog[]
  provider         PaymentProvider
  providerRef      String?  @map("provider_ref")
  amount           Decimal  @db.Decimal(12, 2)
  currency         String   @default("INR")
  status           String
  reason           String?  
  initiatedBy      String?  @map("initiated_by")
  processedAt      DateTime? @map("processed_at")
  metadata         Json?
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  @@index([orderId])
  @@index([attemptId])
  @@map("refunds")
}

model Invoice {
  id             String   @id @default(cuid())
  orderId        String   @unique @map("order_id")
  order          Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  invoiceNumber  String   @unique @map("invoice_number")
  issuedAt       DateTime @default(now()) @map("issued_at")
  dueAt          DateTime? @map("due_at")
  subtotal       Decimal  @db.Decimal(12, 2)
  taxTotal       Decimal  @db.Decimal(12, 2)
  deliveryFee    Decimal  @db.Decimal(12, 2)
  discountTotal  Decimal  @db.Decimal(12, 2)
  total          Decimal  @db.Decimal(12, 2)
  currency       String   @default("INR")
  status         String
  metadata       Json?
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@index([invoiceNumber])
  @@map("invoices")
}

model PaymentAuditLog {
  id            String   @id @default(cuid())
  orderId       String?  @map("order_id")
  order         Order?   @relation(fields: [orderId], references: [id], onDelete: SetNull)
  attemptId     String?  @map("attempt_id")
  attempt       PaymentAttempt? @relation(fields: [attemptId], references: [id], onDelete: SetNull)
  refundId      String?  @map("refund_id")
  refund        Refund?  @relation(fields: [refundId], references: [id], onDelete: SetNull)
  eventType     String   @map("event_type")
  eventSource   String   @map("event_source")
  details       Json?
  createdAt     DateTime @default(now()) @map("created_at")

  @@index([orderId])
  @@index([attemptId])
  @@map("payment_audit_logs")
}

model PaymentEvent {
  id         String   @id @default(cuid())
  attemptId  String?  @map("attempt_id")
  attempt    PaymentAttempt? @relation(fields: [attemptId], references: [id], onDelete: SetNull)
  eventType  String   @map("event_type")
  eventRef   String?  @unique @map("event_ref")
  payload    Json?
  receivedAt DateTime @default(now()) @map("received_at")

  @@index([attemptId])
  @@map("payment_events")
}
