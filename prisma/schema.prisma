generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  name      String?
  email     String   @unique
  password  String
  phone     String?
  address   String?
  city      String?
  zipCode   String?
  role      String   @default("USER") // USER, CONTRACTOR, ADMIN
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  orders    Order[]
}

model Category {
  id          String    @id @default(cuid())
  name        String    @unique
  description String?
  image       String?
  products    Product[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Product {
  id               String   @id @default(cuid())
  name             String
  slug             String   @unique
  description      String
  price            Float
  unit             String   @default("sq.ft") // sq.ft, cubic feet, piece
  stock            Int      @default(0)
  categoryId       String
  category         Category @relation(fields: [categoryId], references: [id])
  
  // Product Details
  thickness        String?
  density          String?
  durabilityScore  Int?
  waterResistant   Boolean  @default(false)
  fireResistant    Boolean  @default(false)
  termiteResistant Boolean  @default(false)
  weight           String?
  dimensions       String?
  grade            String?
  warranty         String?
  deliveryTimeline String?
  
  // Media
  images           String   // JSON array of URLs
  model3D          String?  // URL to GLTF/OBJ model for visualizer
  
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  orderItems       OrderItem[]
}

model Order {
  id              String      @id @default(cuid())
  userId          String?
  user            User?       @relation(fields: [userId], references: [id])
  customerName    String?
  email           String?
  phone           String?
  deliveryAddress String?
  city            String?
  zipCode         String?
  status          String      @default("PENDING") // PENDING, PROCESSING, SHIPPED, DELIVERED
  total           Float
  paymentStatus   String      @default("UNPAID")
  orderItems    OrderItem[]
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model OrderItem {
  id        String   @id @default(cuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id])
  productId String
  product   Product  @relation(fields: [productId], references: [id])
  quantity  Int
  price     Float
}
