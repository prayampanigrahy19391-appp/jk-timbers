    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.4.2",
    "framer-motion": "^12.4.7",
    "lucide-react": "^0.475.0",
    "next": "^16.2.6",
    "next-auth": "^5.0.0-beta.31",
    "react": "^19.0.0",
