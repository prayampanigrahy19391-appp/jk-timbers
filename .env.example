# PostgreSQL Connection
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@localhost:5432/jk_timbers?schema=public"
DIRECT_URL="postgresql://postgres:YOUR_PASSWORD@localhost:5432/jk_timbers?schema=public"

# Authentication (AUTH_SECRET must be at least 8 characters)
NEXTAUTH_URL="http://localhost:3000"
AUTH_SECRET="replace-with-a-strong-secret"
ENABLE_CREDENTIALS="true"
ADMIN_SEED_PASSWORD="replace-with-a-strong-local-seed-password"

# OAuth providers
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# Razorpay sandbox/test credentials
RAZORPAY_KEY_ID="rzp_test_xxxxxxxxxxxxxx"
RAZORPAY_KEY_SECRET="replace-with-razorpay-test-secret"
RAZORPAY_WEBHOOK_SECRET="replace-with-webhook-secret"

# AWS / S3 storage
STORAGE_REGION="us-east-1"
STORAGE_BUCKET="your-bucket-name"
AWS_ACCESS_KEY_ID="your-access-key"
AWS_SECRET_ACCESS_KEY="your-secret-access-key"

# Environment
NODE_ENV="development"
